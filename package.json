{
  "name": "pulse-frontend",
  "private": true,
  "version": "8.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "screenshot:home": "node scripts/screenshot.cjs --route / --output screenshots/home-mobile.png --fullPage",
    "screenshot:sentiment": "node scripts/screenshot.cjs --route /sentiment --output screenshots/sentiment-mobile.png --fullPage",
    "screenshot:desktop": "node scripts/screenshot.cjs --route / --output screenshots/home-desktop.png --fullPage --desktop"
  },
  "dependencies": {
    "@capacitor/browser": "^8.0.3",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@tanstack/react-query": "^5.28.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^11.6.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "puppeteer-core": "^25.2.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
