# Firebase web app config (for push notifications)
# Get these from Firebase Console → Project settings → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Analytics Measurement ID (Firebase Console → Project settings → Web app)
VITE_FIREBASE_MEASUREMENT_ID=

# Web Push VAPID key (Firebase Console → Cloud Messaging → Web push certificates)
VITE_FIREBASE_VAPID_KEY=
